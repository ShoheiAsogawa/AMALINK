# 本番URL（末尾スラッシュなし）。OG・canonical・sitemap・構造化データで使用します。
NEXT_PUBLIC_SITE_URL=https://www.example.com

# microCMS
# https://YOUR-SERVICE.microcms.io の YOUR-SERVICE 部分
MICROCMS_SERVICE_DOMAIN=your-service-domain
# microCMS 管理画面 → API設定 → APIキー からコピー
MICROCMS_API_KEY=your-api-key

# お問い合わせ（Web3Forms: https://web3forms.com ）
# 受信メールはダッシュボードで登録したアドレス（例: uken.shohei@gmail.com）
NEXT_PUBLIC_WEB3FORMS_ACCESS_KEY=your-web3forms-access-key

# 任意: Formspree 等の別エンドポイントを使う場合（Web3Forms 未設定時より優先されない）
# NEXT_PUBLIC_CONTACT_FORM_ENDPOINT=

# 公式LINEの友だち追加URL（未設定時はコード内デフォルト lin.ee を使用）
# NEXT_PUBLIC_OFFICIAL_LINE_URL=https://lin.ee/Sr8rTSa
